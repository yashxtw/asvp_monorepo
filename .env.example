# ----------------------------
# Neon Postgres
# ----------------------------
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require

# ----------------------------
# Postgres
# ----------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ----------------------------
# Redis Cloud
# ----------------------------
# Use your Redis Cloud public endpoint, usually rediss://...
REDIS_URL=
DASHBOARD_CACHE_TTL_SECONDS=120

# ----------------------------
# MinIO (S3 local dev)
# ----------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_ENDPOINT=localhost:9000

# ----------------------------
# Temporal
# ----------------------------
# Primary setup: Temporal Cloud
# Local self-hosted Temporal is optional via:
# docker-compose --profile local-temporal --env-file .env -f docker/docker-compose.yml up -d
TEMPORAL_PORT=7233
TEMPORAL_ADDRESS=ap-northeast-1.aws.api.temporal.io:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=
TEMPORAL_TLS=true

# ----------------------------
# LLM Providers
# ----------------------------
GEMINI_API_KEY=qwertyuiop
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
ENABLE_GEMINI_API=true
SERPAPI_KEY=
SERPAPI_LOCATION=Austin, Texas, United States
SERPAPI_GOOGLE_DOMAIN=google.com
SERPAPI_HL=en
SERPAPI_GL=us
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-3-7-sonnet-20250219

LLM_PROVIDER=gemini
ENABLE_LLM_RECOMMENDATIONS=true
LLM_SERVICE_URL=http://localhost:5050

LLM_RATE_LIMIT_PER_MIN=30
LLM_DEDUPE_TTL_SECONDS=300

# ----------------------------
# Frontend
# ----------------------------
NEXT_PUBLIC_API_BASE=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ----------------------------
# JWT
# ----------------------------
JWT_SECRET=xyz
JWT_EXPIRES_IN=1d

# ----------------------------
# Email
# ----------------------------
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# ----------------------------
# Environment
# ----------------------------
NODE_ENV=development
